            "null"
          ]
        },
        "mission_summary": {
          "type": "string",
          "minLength": 1
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "cwd": {
          "type": "string",
          "minLength": 1
        },
        "terminal_id": {
          "type": "string"
        }
      },
      "required": [
        "model",
        "role",
        "parent_peer_id",
        "mission_summary",
        "capabilities",
        "cwd",
        "terminal_id"
      ],
      "additionalProperties": false
