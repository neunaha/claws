{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "worker-complete-v1",
  "$ref": "#/definitions/worker-complete-v1",
  "definitions": {
    "worker-complete-v1": {
      "type": "object",
      "properties": {
        "result": {
          "type": "string",
          "enum": [
            "ok",
            "failed",
            "cancelled"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "type": {
                "type": "string",
                "minLength": 1
              },
              "size_bytes": {
                "type": "number",
                "minimum": 0
              }
            },
            "required": [
              "path",
              "type"
            ],
            "additionalProperties": false
          }
        },
        "phases_completed": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "PLAN",
              "SPAWN",
              "DEPLOY",
              "OBSERVE",
              "RECOVER",
              "HARVEST",
              "CLEANUP",
              "REFLECT",
              "FAILED"
            ]
          }
        },
        "total_tokens": {
          "type": "number",
          "minimum": 0
        },
        "total_cost_usd": {
          "type": "number",
          "minimum": 0
        },
        "duration_ms": {
          "type": "number",
          "minimum": 0
        }
      },
      "required": [
        "result"
      ],
      "additionalProperties": false
    }
  }
}
