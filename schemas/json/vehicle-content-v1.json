{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "vehicle-content-v1",
  "$ref": "#/definitions/vehicle-content-v1",
  "definitions": {
    "vehicle-content-v1": {
      "type": "object",
      "properties": {
        "terminalId": {
          "type": "string",
          "minLength": 1
        },
        "contentType": {
          "type": "string",
          "enum": [
            "shell",
            "claude",
            "python",
            "node",
            "vim",
            "htop",
            "unknown"
          ]
        },
        "foregroundPid": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0
            },
            {
              "type": "null"
            }
          ]
        },
        "basename": {
          "type": [
            "string",
            "null"
          ]
        },
        "detectedAt": {
          "type": "string",
          "format": "date-time"
        },
        "confidence": {
          "type": "string",
          "enum": [
            "high",
            "low",
            "unknown"
          ]
        }
      },
      "required": [
        "terminalId",
        "contentType",
        "foregroundPid",
        "detectedAt"
      ],
      "additionalProperties": false
    }
  }
}
