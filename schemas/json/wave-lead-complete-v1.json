{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "wave-lead-complete-v1",
  "$ref": "#/definitions/wave-lead-complete-v1",
  "definitions": {
    "wave-lead-complete-v1": {
      "type": "object",
      "properties": {
        "waveId": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "ok",
            "failed",
            "partial"
          ]
        },
        "commits": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "regression_clean": {
          "type": "boolean"
        },
        "duration_sec": {
          "type": "number",
          "minimum": 0
        }
      },
      "required": [
        "waveId",
        "status",
        "commits",
        "regression_clean"
      ],
      "additionalProperties": false
    }
  }
}
