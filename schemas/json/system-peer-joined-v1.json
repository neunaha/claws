            "worker",
            "observer"
          ]
        },
        "peerName": {
          "type": "string",
          "minLength": 1
        },
        "ts": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "peerId",
        "role",
        "peerName",
        "ts"
      ],
      "additionalProperties": false
