            {
              "type": "string",
              "format": "uuid"
            },
            {
              "type": "null"
            }
          ]
        },
        "parent_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "from_peer": {
          "type": "string",
          "minLength": 1
