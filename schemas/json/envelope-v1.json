        "from_name": {
          "type": "string",
          "minLength": 1
        },
        "terminal_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "ts_published": {
          "type": "string",
          "format": "date-time"
        },
        "ts_server": {
          "type": "string",
          "format": "date-time"
        },
        "schema": {
          "type": "string",
          "minLength": 1
        },
        "data": {}
      },
      "required": [
