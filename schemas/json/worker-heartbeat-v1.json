{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "worker-heartbeat-v1",
  "$ref": "#/definitions/worker-heartbeat-v1",
  "definitions": {
    "worker-heartbeat-v1": {
      "type": "object",
      "properties": {
        "current_phase": {
          "type": "string",
          "enum": [
            "PLAN",
            "SPAWN",
            "DEPLOY",
            "OBSERVE",
            "RECOVER",
            "HARVEST",
            "CLEANUP",
            "REFLECT",
            "FAILED"
          ]
        },
        "time_in_phase_ms": {
          "type": "number",
          "minimum": 0
        },
        "tokens_used": {
          "type": "number",
          "minimum": 0
        },
        "cost_usd": {
          "type": "number",
          "minimum": 0
        },
        "last_event_id": {
          "anyOf": [
            {
              "type": "string",
              "format": "uuid"
            },
            {
              "type": "null"
            }
          ]
        },
        "active_sub_workers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "kind": {
          "type": "string",
          "enum": [
            "progress",
            "heartbeat",
            "approach",
            "error",
            "mission_complete",
            "mission_failed"
          ]
        },
        "summary": {
          "type": "string"
        },
        "current_action": {
          "type": "string"
        },
        "duration_ms": {
          "type": "number",
          "minimum": 0
        },
        "tokens_in": {
          "type": "number",
          "minimum": 0
        },
        "tokens_out": {
          "type": "number",
          "minimum": 0
        },
        "total_cost_usd": {
          "type": "number",
          "minimum": 0
        },
        "total_duration_ms": {
          "type": "number",
          "minimum": 0
        },
        "total_tool_calls": {
          "type": "number",
          "minimum": 0
        },
        "captured_at": {
          "type": "string",
          "format": "date-time"
        },
        "correlation_id": {
          "type": "string"
        },
        "error_detail": {
          "type": "string"
        },
        "approach_detail": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  }
}
