# ── Build artifacts (generated on install, never committed) ────────────────
node_modules/
dist/
out/
build/
# Codegen temp bundle — generated by `npm run schemas`, not committed
extension/dist/event-schemas.bundle.cjs
# Native bundle metadata — bundle-native.mjs rewrites bundledAt timestamp on
# every install; tracking it dirties the source tree and blocks the P3 hygiene
# guard in install.sh on every user's second install (universal v0.7.10 bug).
extension/native/.metadata.json
*.vsix
*.tsbuildinfo
.vscode-test/
coverage/

# ── Installer output (created in project roots by scripts/install.sh) ──────
# Ignored here so running the installer inside the Claws repo itself during
# testing doesn't leak the vendored copies into version control.
.claws-bin/
.mcp.json

# ── Local development only (never ships to GitHub) ─────────────────────────
# Roadmap, audits, internal planning docs, scratch notes. Put anything here
# that informs *how* the product is built but isn't the product itself.
.local/
NOTES.md
TODO.md
SCRATCH.md

# ── Runtime artifacts ──────────────────────────────────────────────────────
.claws/
*.sock
*.log
.claude/scheduled_tasks.lock

# ── Secrets ────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Editor / OS ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/

# ── Python legacy (clients/python/ is optional, guard against bytecode) ────
__pycache__/
*.pyc
*.egg-info/

# Marketing assets — internal only
claws_marketing/
